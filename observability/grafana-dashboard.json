{
  "title": "Production Microservice",
  "uid": "prod-microservice",
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "tags": ["microservice", "smaitic"],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "constant",
        "query": "production",
        "current": { "text": "production", "value": "production" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request rate (RPS)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count[5m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate (5xx %)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 * sum(rate(http_request_duration_seconds_count{status_code=~\"5..\"}[5m])) / sum(rate(http_request_duration_seconds_count[5m]))",
          "legendFormat": "5xx %"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Pod CPU / Memory & replicas",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", pod=~\"production-microservice.*\"}[5m]))",
          "legendFormat": "cpu cores"
        },
        {
          "expr": "kube_deployment_status_replicas_available{namespace=\"$namespace\", deployment=\"production-microservice\"}",
          "legendFormat": "ready replicas"
        }
      ]
    }
  ]
}
